{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd webapp && bun run build",
  "outputDirectory": "webapp/dist",
  "installCommand": "cd webapp && bun install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
