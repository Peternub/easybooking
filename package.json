{
  "name": "telegram-booking-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["bot", "webapp", "shared"],
  "scripts": {
    "bot:dev": "bun --watch bot/src/index.ts",
    "webapp:dev": "cd webapp && bun run dev",
    "start": "bun run server.ts",
    "build": "cd webapp && bun install && bun run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2"
  }
}
